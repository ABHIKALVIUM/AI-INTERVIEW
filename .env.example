# =============================================================================
# AI Mock Interview Platform — Environment Variables
# Copy to .env and fill in all values before running
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://interview_user:interview_pass@localhost:5432/interview_db

# --- JWT (httpOnly cookies) ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Groq (LLM — free tier at console.groq.com) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- LiveKit Cloud (free tier at livekit.io) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- Deepgram (STT — free tier at deepgram.com — 12,000 min/yr) ---
DEEPGRAM_API_KEY=your_deepgram_api_key

# --- Cartesia (TTS — free tier at cartesia.ai — 10,000 chars/month) ---
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_MODEL_ID=sonic-english
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# --- CORS ---
FRONTEND_URL=http://localhost:5173

# --- Ports ---
API_PORT=3001
AGENT_PORT=3002

# --- Node environment ---
NODE_ENV=development
